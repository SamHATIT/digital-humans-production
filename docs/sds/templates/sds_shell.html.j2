<tr class='tbl-row-detail' id='detail-uc_index-BR-002'><td colspan='5'><div class='tbl-detail-body uc-cards'>
<div class='uc-card'>
<div class='uc-card-head'>
<span class='req-code uc'>UC-002-01</span>
<span class='uc-card-title'>Update Vehicle Condition/Status to Reflect Operational State</span>
</div>
<dl class='detail-kv'>
