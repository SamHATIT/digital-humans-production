<tr class='tbl-row-detail' id='detail-uc_index-BR-003'><td colspan='5'><div class='tbl-detail-body uc-cards'>
<div class='uc-card'>
<div class='uc-card-head'>
<span class='req-code uc'>UC-003-01</span>
<span class='uc-card-title'>Create a New Rental Contract Linking Client to Vehicle</span>
</div>
<dl class='detail-kv'>
