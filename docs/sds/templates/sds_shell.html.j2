<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SDS · LogiFleet #146 — Digital·Humans Studio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #0A0A0B; --ink-2: #141416; --ink-3: #1C1C1F;
    --bone: #F5F2EC; --bone-2: #E8E3D9; --bone-3: #B8B2A6; --bone-4: #76716A;
    --brass: #C8A97E; --brass-3: #8C6E4A;
    --sage: #7A9B76; --slate: #6B7A8F; --ochre: #B8954A; --terra: #B8745C; --plum: #8E6B8E;
    --rail: 1px solid rgba(245,242,236,0.08);
    --rail-brass: 1px solid rgba(200,169,126,0.32);
    --serif: 'Cormorant Garamond', Georgia, serif;
    --sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --mono: 'JetBrains Mono', ui-monospace, monospace;
    --header-h: 62px;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { background: var(--ink); color: var(--bone); font-family: var(--sans); -webkit-font-smoothing: antialiased; line-height: 1.6; font-size: 14px; }
  a { color: inherit; }
  em { font-style: italic; }
  strong { font-weight: 600; color: var(--bone); }
  code, tt { font-family: var(--mono); font-size: 12.5px; }
  .wrap { max-width: 1160px; margin: 0 auto; padding: 0 48px; }
  @media (max-width: 760px) { .wrap { padding: 0 24px; } }
  section, h2[id] { scroll-margin-top: calc(var(--header-h) + 24px); }

  header.glass { position: sticky; top: 0; z-index: 50; background: rgba(10,10,11,0.82); backdrop-filter: blur(14px) saturate(130%); border-bottom: var(--rail); }
  header .bar { display: flex; align-items: center; justify-content: space-between; padding: 16px 0; }
  .mk { display: flex; align-items: baseline; gap: 14px; text-decoration: none; }
  .mk .wm { font-family: var(--serif); font-size: 22px; font-weight: 500; color: var(--bone); letter-spacing: -0.02em; }
  .mk .wm em { font-style: italic; color: var(--brass); font-weight: 400; }
  .mk .wm .dot { color: var(--brass-3); margin: 0 1px; }
  .mk .tag { font-family: var(--mono); font-size: 9px; letter-spacing: 2.5px; text-transform: uppercase; color: var(--bone-4); padding-left: 14px; border-left: 1px solid rgba(245,242,236,0.16); }
  header .meta { font-family: var(--mono); font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--bone-4); display: flex; gap: 16px; align-items: center; }
  header .meta .dot { color: var(--brass-3); }
  header .meta .pill { padding: 4px 10px; border: 1px solid rgba(245,242,236,0.08); color: var(--bone-3); }
  header .meta .pill.ok { color: var(--sage); border-color: rgba(122,155,118,0.3); }
  header .print-btn { font-family: var(--mono); font-size: 9.5px; letter-spacing: 1.5px; text-transform: uppercase; padding: 6px 12px; background: transparent; color: var(--bone-3); border: 1px solid var(--brass-3); cursor: pointer; border-radius: 2px; transition: all 0.2s ease; }
  header .print-btn:hover { color: var(--bone); background: rgba(200,169,126,0.06); border-color: var(--brass); }
  @media (max-width: 860px) { header .meta .hide-mob { display: none; } }

  .hero { position: relative; padding: 88px 0 64px; overflow: hidden; }
  .hero::before { content: ""; position: absolute; inset: 0; z-index: 0; background-image: linear-gradient(rgba(245,242,236,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(245,242,236,0.025) 1px, transparent 1px); background-size: 64px 64px; mask-image: radial-gradient(ellipse at 70% 30%, black 30%, transparent 80%); -webkit-mask-image: radial-gradient(ellipse at 70% 30%, black 30%, transparent 80%); }
  .hero::after { content: ""; position: absolute; width: 720px; height: 720px; border-radius: 50%; top: -280px; right: -180px; background: radial-gradient(circle at 35% 35%, rgba(200,169,126,0.22), transparent 60%); pointer-events: none; filter: blur(8px); z-index: 0; }
  .hero .wrap { position: relative; z-index: 1; }
  .eyebrow { font-family: var(--mono); font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: var(--brass); display: inline-block; margin-bottom: 24px; }
  .eyebrow::before { content: "— "; color: var(--brass-3); margin-right: 4px; }
  .hero h1 { font-family: var(--serif); font-weight: 500; font-size: clamp(44px, 7vw, 78px); color: var(--bone); letter-spacing: -0.025em; line-height: 1.03; max-width: 18ch; margin-bottom: 24px; }
  .hero h1 em { font-style: italic; font-weight: 400; color: var(--brass); }
  .hero .sub { max-width: 60ch; font-size: 16px; color: var(--bone-3); line-height: 1.65; margin-bottom: 40px; }
  .hero-meta { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0; border-top: var(--rail-brass); border-left: var(--rail); margin-top: 20px; }
  .hero-meta .cell { padding: 18px 20px; border-right: var(--rail); border-bottom: var(--rail); background: rgba(20,20,22,0.4); }
  .hero-meta .k { font-family: var(--mono); font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: var(--bone-4); margin-bottom: 8px; }
  .hero-meta .v { font-family: var(--serif); font-size: 20px; font-weight: 500; color: var(--bone); letter-spacing: -0.01em; line-height: 1.2; }
  .hero-meta .v em { font-style: italic; color: var(--brass); font-weight: 400; }
  .hero-meta .v.sm { font-size: 14px; font-family: var(--sans); font-weight: 400; color: var(--bone-3); }
  .hero-meta .v.sm.brass { color: var(--brass); font-family: var(--mono); font-size: 11px; letter-spacing: 1px; }
  .hero-note { margin-top: 28px; font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.8px; color: var(--bone-4); max-width: 78ch; padding-left: 14px; border-left: 1px solid var(--brass-3); }

  .toc-block { padding: 80px 0; border-top: var(--rail-brass); }
  .toc-head { display: grid; grid-template-columns: 220px 1fr; gap: 48px; padding-bottom: 40px; border-bottom: var(--rail); margin-bottom: 40px; align-items: baseline; }
  .toc-head .num { font-family: var(--mono); font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: var(--brass); }
  .toc-head .num::before { content: "— "; color: var(--brass-3); margin-right: 4px; }
  .toc-head h2 { font-family: var(--serif); font-size: clamp(32px, 4.6vw, 44px); font-weight: 500; color: var(--bone); letter-spacing: -0.02em; line-height: 1.05; }
  .toc-head h2 em { font-style: italic; color: var(--brass); font-weight: 400; }
  @media (max-width: 760px) { .toc-head { grid-template-columns: 1fr; gap: 14px; } }
  .toc { display: flex; flex-direction: column; border-top: var(--rail); }
  .toc-row { display: grid; grid-template-columns: 64px 1fr 220px 200px; gap: 24px; align-items: baseline; padding: 18px 0; border-bottom: var(--rail); text-decoration: none; color: inherit; transition: background 0.2s ease, padding 0.2s ease; }
  .toc-row:hover { background: linear-gradient(90deg, rgba(200,169,126,0.04), transparent 70%); padding-left: 12px; }
  .toc-num { font-family: var(--mono); font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--brass); }
  .toc-title { font-family: var(--serif); font-size: 22px; font-weight: 500; color: var(--bone); letter-spacing: -0.01em; }
  .toc-author { font-family: var(--sans); font-size: 12px; color: var(--bone-3); }
  .toc-artifact { font-family: var(--mono); font-size: 9.5px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--bone-4); text-align: right; }
  @media (max-width: 860px) { .toc-row { grid-template-columns: 40px 1fr; gap: 12px; } .toc-author, .toc-artifact { display: none; } }

  /* Reading layout */
  .reading-layout { display: grid; grid-template-columns: 240px 1fr; gap: 48px; max-width: 1280px; margin: 0 auto; padding: 0 40px; }
  .reading-main { min-width: 0; }
  .reading-main .wrap { max-width: 900px; margin: 0; padding: 0; }
  @media (max-width: 1100px) {
    .reading-layout { grid-template-columns: 1fr; padding: 0 24px; }
    .toc-side { display: none; }
  }

  /* Sticky TOC */
  .toc-side { position: sticky; top: calc(var(--header-h) + 24px); align-self: start; max-height: calc(100vh - var(--header-h) - 48px); overflow-y: auto; padding: 24px 20px 32px 0; border-right: var(--rail); }
  .toc-side::-webkit-scrollbar { width: 4px; }
  .toc-side::-webkit-scrollbar-track { background: transparent; }
  .toc-side::-webkit-scrollbar-thumb { background: var(--brass-3); opacity: 0.3; }
  .toc-side-label { font-family: var(--mono); font-size: 9.5px; letter-spacing: 2.5px; text-transform: uppercase; color: var(--brass); margin-bottom: 20px; }
  .toc-side-label::before { content: "— "; color: var(--brass-3); }
  .toc-side-list, .toc-side-sublist { list-style: none; }
  .toc-side-item { padding: 2px 0; border-left: 1px solid transparent; padding-left: 12px; margin-left: -13px; }
  .toc-side-item.active { border-left-color: var(--brass); }
  .toc-side-link { display: flex; gap: 10px; padding: 6px 0; text-decoration: none; color: var(--bone-3); font-size: 12.5px; line-height: 1.4; transition: color 0.15s ease; }
  .toc-side-link:hover { color: var(--bone); }
  .toc-side-item.active .toc-side-link { color: var(--bone); }
  .toc-side-num { font-family: var(--mono); font-size: 10px; color: var(--brass); min-width: 22px; letter-spacing: 1px; text-transform: uppercase; padding-top: 2px; }
  .toc-side-title { font-family: var(--serif); font-size: 14.5px; }
  .toc-side-sublist { padding: 2px 0 6px 32px; max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
  .toc-side-item.active .toc-side-sublist { max-height: 800px; }
  .toc-side-sublist li { padding: 3px 0; }
  .toc-side-sublist a { font-family: var(--mono); font-size: 10.5px; color: var(--bone-4); text-decoration: none; letter-spacing: 0.3px; transition: color 0.15s ease; }
  .toc-side-sublist a:hover { color: var(--brass); }

  section.block { padding: 96px 0 24px; border-top: var(--rail-brass); position: relative; }
  .act { font-family: var(--mono); font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: var(--brass); margin-bottom: 18px; display: flex; align-items: center; gap: 14px; }
  .act-num::before { content: "— "; color: var(--brass-3); }
  .act-sep { flex: 0 0 48px; height: 1px; background: var(--brass-3); opacity: 0.4; }
  .act-tag { color: var(--bone-4); }
  h1.sec-h1 { font-family: var(--serif); font-weight: 500; font-size: clamp(34px, 5vw, 52px); color: var(--bone); letter-spacing: -0.025em; line-height: 1.05; margin-bottom: 44px; max-width: 26ch; }
  h1.sec-h1 em.brass { font-style: italic; color: var(--brass); font-weight: 400; }
  h2.sec-h2 { font-family: var(--serif); font-weight: 500; font-size: clamp(22px, 2.6vw, 28px); color: var(--bone); letter-spacing: -0.02em; line-height: 1.15; margin: 48px 0 18px; padding-top: 24px; border-top: var(--rail); }
  h2.sec-h2 em.brass { font-style: italic; color: var(--brass); font-weight: 400; }
  h3.sec-h3 { font-family: var(--mono); font-size: 11px; font-weight: 500; letter-spacing: 2.5px; text-transform: uppercase; color: var(--brass); margin: 36px 0 14px; }
  h3.sec-h3::before { content: "— "; color: var(--brass-3); }
  h4.sec-h4 { font-family: var(--sans); font-size: 13px; font-weight: 600; color: var(--bone-3); margin: 24px 0 10px; letter-spacing: 0.3px; }
  p { font-size: 14.5px; color: var(--bone-2); line-height: 1.7; max-width: 78ch; margin: 0 0 16px; }
  p.note { font-family: var(--serif); font-style: italic; font-size: 15px; color: var(--bone-3); padding-left: 14px; border-left: 1px solid var(--brass-3); max-width: 80ch; margin: 18px 0; }

  .figure-block { margin: 36px 0 44px; }
  .figure-caption { font-family: var(--mono); font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--bone-4); margin-bottom: 14px; }
  .figure-caption::before { content: "— "; color: var(--brass-3); }
  .mermaid-wrap { background: var(--ink-2); border: var(--rail); border-left: 2px solid var(--brass); padding: 32px 24px; overflow-x: auto; text-align: center; }
  .mermaid-wrap svg { max-width: 100%; height: auto; display: inline-block; }

  .req-head { display: flex; align-items: baseline; gap: 14px; margin: 36px 0 6px; padding-bottom: 10px; border-bottom: 1px solid rgba(200,169,126,0.18); flex-wrap: wrap; }
  .req-code { font-family: var(--mono); font-size: 10.5px; letter-spacing: 1.5px; color: var(--brass); padding: 3px 9px; border: 1px solid rgba(200,169,126,0.3); background: rgba(200,169,126,0.05); }
  .req-code.uc { color: var(--slate); border-color: rgba(107,122,143,0.3); background: rgba(107,122,143,0.05); }
  .req-title { font-family: var(--serif); font-size: 20px; font-weight: 500; color: var(--bone); letter-spacing: -0.01em; line-height: 1.2; }
  .uc-group { display: flex; align-items: baseline; gap: 14px; margin: 40px 0 14px; padding: 14px 18px; background: var(--ink-2); border-left: 2px solid var(--brass); }
  .uc-group-code { font-family: var(--mono); font-size: 11px; letter-spacing: 1.5px; color: var(--brass); }
  .uc-group-count { font-family: var(--serif); font-style: italic; font-size: 16px; color: var(--bone-3); }

  /* ═══ UC Accordion — groups of use cases per Business Requirement ═══ */
  details.uc-accordion { margin: 24px 0 8px; background: var(--ink-2); border-left: 2px solid var(--brass); border-top: var(--rail); border-right: var(--rail); border-bottom: var(--rail); overflow: hidden; transition: background 0.2s ease; }
  details.uc-accordion[open] { background: var(--ink-2); border-left-color: var(--brass); }
  details.uc-accordion:not([open]):hover { background: rgba(200,169,126,0.04); }
  details.uc-accordion > summary { display: flex; align-items: baseline; gap: 14px; padding: 16px 18px; cursor: pointer; list-style: none; user-select: none; }
  details.uc-accordion > summary::-webkit-details-marker { display: none; }
  .uc-accordion-chevron { display: inline-block; width: 10px; height: 10px; border-right: 1.5px solid var(--brass); border-bottom: 1.5px solid var(--brass); transform: rotate(-45deg); transition: transform 0.22s ease; margin-right: 4px; position: relative; top: -2px; flex-shrink: 0; }
  details.uc-accordion[open] .uc-accordion-chevron { transform: rotate(45deg); top: -4px; }
  .uc-accordion-hint { margin-left: auto; font-family: var(--mono); font-size: 9px; letter-spacing: 1.8px; text-transform: uppercase; color: var(--bone-4); transition: opacity 0.2s ease; }
  details.uc-accordion[open] .uc-accordion-hint { opacity: 0; }
  .uc-accordion-body { padding: 4px 18px 20px 36px; border-top: 1px solid rgba(200,169,126,0.1); background: rgba(10,10,11,0.35); animation: uc-fade 0.25s ease-out; }
  .uc-accordion-body > .req-head:first-child { margin-top: 18px; }
  @keyframes uc-fade { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }

  /* ═══ Expandable table rows (BR summary / UC index) ═══ */
  .tbl-expand .tbl-toggle-col { width: 36px; padding: 12px 0 12px 14px !important; }
  .tbl-expand .tbl-toggle { width: 36px; padding: 11px 0 11px 14px !important; text-align: left; }
  .tbl-expand .tbl-caret { display: inline-block; width: 7px; height: 7px; border-right: 1.2px solid var(--brass); border-bottom: 1.2px solid var(--brass); transform: rotate(-45deg); transition: transform 0.2s ease; position: relative; top: -2px; }
  .tbl-expand tr.tbl-row-summary { cursor: pointer; transition: background 0.15s ease; }
  .tbl-expand tr.tbl-row-summary:hover { background: rgba(200,169,126,0.05); }
  .tbl-expand tr.tbl-row-summary:focus-visible { outline: 1px solid var(--brass); outline-offset: -1px; }
  .tbl-expand tr.tbl-row-summary.open { background: rgba(200,169,126,0.08); }
  .tbl-expand tr.tbl-row-summary.open .tbl-caret { transform: rotate(45deg); top: -4px; }
  .tbl-expand tr.tbl-row-detail { display: none; }
  .tbl-expand tr.tbl-row-detail > td { padding: 0 !important; background: rgba(10,10,11,0.55) !important; border-bottom: var(--rail) !important; }
  .tbl-expand tr.tbl-row-summary.open + tr.tbl-row-detail { display: table-row; }
  .tbl-detail-body { padding: 20px 28px 24px 52px; border-left: 2px solid var(--brass); animation: row-fade 0.25s ease-out; }
  @keyframes row-fade { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }
  .detail-desc { font-family: var(--serif); font-style: italic; font-size: 15.5px; color: var(--bone-2); line-height: 1.65; margin: 0 0 18px; padding-left: 14px; border-left: 1px solid rgba(200,169,126,0.35); max-width: 80ch; }
  .detail-kv { display: grid; grid-template-columns: 170px 1fr; gap: 8px 28px; font-size: 13px; }
  .detail-kv dt { font-family: var(--mono); font-size: 9.5px; letter-spacing: 1.6px; text-transform: uppercase; color: var(--bone-4); padding-top: 3px; }
  .detail-kv dt::before { content: "— "; color: var(--brass-3); }
  .detail-kv dd { color: var(--bone-2); line-height: 1.6; margin: 0; }

  /* UC cards inside UC-index expandable rows */
  .uc-cards { padding: 20px 28px 24px 52px; display: flex; flex-direction: column; gap: 20px; animation: row-fade 0.25s ease-out; border-left: 2px solid var(--brass); }
  .uc-card { background: var(--ink-2); border: var(--rail); padding: 16px 20px; }
  .uc-card-head { display: flex; align-items: baseline; gap: 12px; margin-bottom: 12px; padding-bottom: 10px; border-bottom: 1px solid rgba(107,122,143,0.2); flex-wrap: wrap; }
  .uc-card-title { font-family: var(--serif); font-size: 17px; font-weight: 500; color: var(--bone); letter-spacing: -0.01em; line-height: 1.25; }
  .uc-card .detail-kv { grid-template-columns: 130px 1fr; font-size: 12.5px; gap: 6px 20px; }

  .tbl { width: 100%; border-collapse: collapse; margin: 16px 0 28px; font-size: 13px; background: var(--ink-2); border: var(--rail); }
  .tbl thead th { background: var(--ink-3); font-family: var(--mono); font-size: 9.5px; letter-spacing: 2px; text-transform: uppercase; font-weight: 500; color: var(--brass); text-align: left; padding: 12px 14px; border-bottom: 1px solid rgba(200,169,126,0.2); }
  .tbl tbody td { padding: 11px 14px; border-bottom: var(--rail); vertical-align: top; color: var(--bone-2); line-height: 1.55; }
  .tbl tbody tr:last-child td { border-bottom: none; }
  .tbl tbody tr:hover { background: rgba(200,169,126,0.03); }
  .tbl tbody td strong { color: var(--bone); }
  .tbl tbody td em { font-family: var(--serif); font-style: italic; color: var(--bone-3); }
  .tbl.tbl-kv { background: transparent; border: none; max-width: 900px; }
  .tbl.tbl-kv tbody td { border-bottom: var(--rail); padding: 10px 16px 10px 0; }
  .tbl.tbl-kv tbody td:first-child { font-family: var(--mono); font-size: 10.5px; letter-spacing: 1.5px; color: var(--bone-4); text-transform: uppercase; font-weight: 400; width: 220px; white-space: nowrap; }
  .tbl.tbl-kv tbody td:first-child strong { font-weight: 400; color: var(--bone-4); }

  .td-json { padding: 10px 14px !important; }
  .tbl.tbl-nested { background: var(--ink-3); border: var(--rail); margin: 4px 0; font-size: 12px; }
  .tbl.tbl-nested thead th { background: rgba(200,169,126,0.04); font-size: 8.5px; padding: 8px 10px; }
  .tbl.tbl-nested tbody td { padding: 8px 10px; }
  .tbl.tbl-nested.tbl-kv tbody td:first-child { width: 140px; padding: 6px 10px 6px 0; font-size: 9.5px; }
  .tbl.tbl-nested .tbl-nested { background: var(--ink); }
  .key { font-family: var(--mono); font-size: 10px; letter-spacing: 1px; text-transform: uppercase; color: var(--bone-4); }
  .chiprow { display: flex; flex-wrap: wrap; gap: 6px; }
  .chip { font-family: var(--mono); font-size: 10.5px; padding: 2px 8px; background: rgba(200,169,126,0.06); border: 1px solid rgba(200,169,126,0.2); color: var(--bone-2); border-radius: 2px; letter-spacing: 0.2px; }
  .json-bool { color: var(--plum); }
  .json-num { color: var(--sage); }
  .trunc-note { font-family: var(--mono); font-size: 9px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--bone-4); margin-top: 8px; padding-top: 6px; border-top: 1px dashed rgba(200,169,126,0.15); }
  .muted { color: var(--bone-4); opacity: 0.55; }

  .cta { position: relative; padding: 96px 0; border-top: var(--rail-brass); border-bottom: var(--rail-brass); overflow: hidden; margin-top: 80px; }
  .cta::before { content: ""; position: absolute; width: 520px; height: 520px; border-radius: 50%; top: -260px; right: -160px; background: radial-gradient(circle at 35% 35%, rgba(200,169,126,0.16), transparent 60%); filter: blur(6px); pointer-events: none; }
  .cta .wrap { position: relative; z-index: 1; }
  .cta h2 { font-family: var(--serif); font-weight: 500; font-size: clamp(30px, 4.6vw, 48px); color: var(--bone); letter-spacing: -0.025em; line-height: 1.05; max-width: 20ch; margin-bottom: 20px; }
  .cta h2 em { font-style: italic; color: var(--brass); font-weight: 400; }
  .cta p { font-size: 15px; color: var(--bone-3); max-width: 58ch; }
  footer { padding: 40px 0 56px; }
