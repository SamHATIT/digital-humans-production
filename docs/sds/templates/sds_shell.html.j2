<script>
(function() {
  // Before printing: open every UC accordion so content isn't clipped in PDF.
  // After print dialog closes: restore original state.
  const originalStates = new WeakMap();
  function beforePrint() {
    document.querySelectorAll('details.uc-accordion').forEach(d => {
      originalStates.set(d, d.open);
      d.open = true;
    });
  }
  function afterPrint() {
    document.querySelectorAll('details.uc-accordion').forEach(d => {
      if (originalStates.has(d)) d.open = originalStates.get(d);
    });
  }
  window.addEventListener('beforeprint', beforePrint);
  window.addEventListener('afterprint', afterPrint);
  // Also expose manual trigger for the Print button
  window.__prepareAndPrint = function() {
    beforePrint();
    // Give the DOM a tick to repaint before print dialog
    setTimeout(() => {
      window.print();
      // afterprint event will restore; fallback in case:
      setTimeout(afterPrint, 300);
    }, 50);
  };
})();
</script>

<script>
(function() {
  // Expandable table rows (BR summary, UC index)
  const summaries = document.querySelectorAll('tr.tbl-row-summary');
  summaries.forEach(tr => {
    const toggle = () => {
      const isOpen = tr.classList.toggle('open');
      tr.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    };
    tr.addEventListener('click', toggle);
    tr.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        toggle();
      }
    });
  });

  // Also open expandable rows before print (same pattern as accordions)
  const originalRowStates = new WeakMap();
  window.addEventListener('beforeprint', () => {
    summaries.forEach(tr => {
      originalRowStates.set(tr, tr.classList.contains('open'));
      tr.classList.add('open');
      tr.setAttribute('aria-expanded', 'true');
    });
  });
  window.addEventListener('afterprint', () => {
    summaries.forEach(tr => {
      if (originalRowStates.has(tr) && !originalRowStates.get(tr)) {
        tr.classList.remove('open');
        tr.setAttribute('aria-expanded', 'false');
      }
    });
  });
})();
</script>

<script>
(function() {
  const items = document.querySelectorAll('.toc-side-item');
  if (!items.length) return;
  const map = {};
  items.forEach(it => { map[it.dataset.sec] = it; });

  const observer = new IntersectionObserver((entries) => {
    let best = null;
    entries.forEach(e => {
      if (e.isIntersecting) {
        if (!best || e.boundingClientRect.top < best.boundingClientRect.top) best = e;
      }
    });
    if (best) {
      items.forEach(it => it.classList.remove('active'));
      const id = best.target.id;
      if (map[id]) map[id].classList.add('active');
    }
  }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });

  document.querySelectorAll('section.block').forEach(s => observer.observe(s));
  if (items[0]) items[0].classList.add('active');
})();
</script>

