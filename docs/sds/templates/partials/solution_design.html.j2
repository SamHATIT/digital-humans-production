<p>- {"name":"Share_Overdue_Invoices_With_Managers","object":"Invoice__c","type":"Criteria-Based","criteria":"Payment_Status__c = 'Overdue'","shared_with":"Fleet_Managers_Group","access":"Read Only"}</p>
<p>- {"name":"Share_Incident_Reports_With_Fleet_Ops","object":"Incident_Report__c","type":"Owner-Based","criteria":"Owned by Fleet_Operations_Queue","shared_with":"Fleet_Managers_Group","access":"Read/Write"}</p>
