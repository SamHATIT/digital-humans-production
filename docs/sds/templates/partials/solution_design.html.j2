{# ═════════════════════════════════════════════════════════════════════
   Macro render_value : rendu recursif d'une valeur JSON arbitraire en HTML
   Utilise pour 6.9 Integration Points et toute future structure imbriquee.
   ═════════════════════════════════════════════════════════════════════ #}
{% macro render_value(v, key='') -%}
{%- if key in ['uc_refs', 'UC refs'] -%}
{{ v | join(', ') }}
{%- elif v is mapping -%}
<table class='tbl tbl-kv tbl-nested'><tbody>
{%- for k, val in v.items() %}
<tr><td><span class='key'>{{ k | humanize }}</span></td><td>{{ render_value(val, k) }}</td></tr>
{%- endfor %}
</tbody></table>
{%- elif v is sequence and v is not string -%}
{%- if v | length == 0 -%}
<span class='muted'>—</span>
{%- else -%}
<div class='chiprow'>{% for item in v %}<span class='chip'>{{ item }}</span>{% if not loop.last %} {% endif %}{% endfor %}</div>
{%- endif -%}
{%- elif v is number and v is not boolean -%}
<code class='json-num'>{{ v }}</code>
{%- else -%}
{{ v }}
{%- endif -%}
{%- endmacro %}
<h2 id='sub-6-9' class='sec-h2'><span>6.9 Integration Points</span> <em class='brass'>({{ integration_points | length }})</em></h2>
{% for ip in integration_points %}<p><strong>{{ ip.name }}</strong></p>
<table class='tbl'>
<thead><tr>
<th>system</th>
<th>{{ ip.system }}</th>
</tr></thead>
<tbody>
{%- set ordered_keys = ['direction', 'method', 'frequency', 'auth', 'rate_limits', 'named_credential', 'uc_refs', 'endpoint_spec', 'error_handling'] %}
{%- for k in ordered_keys %}
{%- if k in ip %}
<tr>
<td>{{ k | humanize }}</td>
{%- if ip[k] is mapping %}
<td class='td-json'>{{ render_value(ip[k], k) }}</td>
{%- else %}
<td>{{ render_value(ip[k], k) }}</td>
{%- endif %}
</tr>
{%- endif %}
{%- endfor %}
{#- Cles inconnues : on les ajoute a la fin pour ne rien perdre #}
{%- for k, v in ip.items() %}
{%- if k not in ordered_keys and k not in ['name', 'system'] %}
<tr>
<td>{{ k | humanize }}</td>
{%- if v is mapping %}
<td class='td-json'>{{ render_value(v, k) }}</td>
{%- else %}
<td>{{ render_value(v, k) }}</td>
{%- endif %}
</tr>
{%- endif %}
{%- endfor %}
</tbody></table>
{% endfor %}
